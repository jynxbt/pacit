platform :ios, '15.0'
use_frameworks!

install! 'cocoapods', :disable_input_output_paths => true

target 'BenchHost' do
  pod 'Capacitor', :path => '../../../ios'
  pod 'CapacitorCordova', :path => '../../../ios'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Compile signposts into Capacitor when BenchHost builds
      if target.name == 'Capacitor'
        existing = config.build_settings['OTHER_SWIFT_FLAGS'] || '$(inherited)'
        config.build_settings['OTHER_SWIFT_FLAGS'] = "#{existing} -D PACIT_BENCH"
      end
    end
  end
end
